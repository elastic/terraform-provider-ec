{
  "extends": [
    "config:recommended"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "gitIgnoredAuthors": [
    "150874479+elastic-vault-github-plugin-prod[bot]@users.noreply.github.com"
  ],
  "automerge": true,
  "automergeType": "pr",
  "packageRules": [
    {
      "groupName": "github.com/oapi-codegen dependencies",
      "matchPackageNames": [
        "github.com/oapi-codegen/*"
      ]
    },
    {
      "groupName": "github.com/hashicorp dependencies",
      "matchPackageNames": [
        "github.com/hashicorp/*"
      ]
    }
  ],
  "major": {
    "automerge": false
  }
}
